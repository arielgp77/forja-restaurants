generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

enum TenantStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum TenantPlan {
  LOCAL_PREMIUM
  SAAS_BASIC
  SAAS_PRO
  INTERNAL_DEMO
}

enum RestaurantStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum StorySectionType {
  HERO
  OUR_STORY
  OWNER_STORY
  FEATURED_DISHES
  COMMUNITY
  PROMO
  GALLERY
  CTA
}

enum ServiceType {
  GENERAL
  PICKUP
  CURBSIDE
  DELIVERY
}

enum SelectionType {
  SINGLE
  MULTIPLE
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PLACED
  CONFIRMED
  PREPARING
  READY
  HANDOFF
  COMPLETED
  CANCELLED
  REFUNDED
}

enum FulfillmentType {
  PICKUP
  CURBSIDE
  DELIVERY
}

enum SourceChannel {
  WEB
  CHAT
  SMS
  ADMIN
  PHONE_MANUAL
}

enum ActorType {
  SYSTEM
  CUSTOMER
  STAFF
  AI
  DRIVER
  ADMIN
}

enum DriverStatus {
  INACTIVE
  ACTIVE
  PAUSED
}

enum ConversationChannel {
  WEB_CHAT
  SMS
  ADMIN_MANUAL
}

enum ConversationStatus {
  OPEN
  CLOSED
  ESCALATED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum SenderType {
  CUSTOMER
  SYSTEM
  STAFF
  AI
  DRIVER
}

enum MessageType {
  TEXT
  EVENT
  SYSTEM_PROMPT
}

enum MessageDeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  UNKNOWN
}

enum PaymentProvider {
  STRIPE
  CASH
  MANUAL
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  CANCELLED
}

enum LedgerEntryType {
  SUBTOTAL
  TAX
  SERVICE_FEE
  DELIVERY_FEE
  TIP
  DISCOUNT
  PLATFORM_FEE
  REFUND
  ADJUSTMENT
}

enum PromoType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_DELIVERY
}

enum RuleType {
  ORDERING
  MESSAGING
  PRICING
  VISIBILITY
  FULFILLMENT
  FEATURE
}

model Tenant {
  id              String       @id @default(cuid())
  slug            String       @unique
  name            String
  status          TenantStatus @default(DRAFT)
  plan            TenantPlan   @default(LOCAL_PREMIUM)
  defaultLocale   String       @default("en")
  defaultCurrency String       @default("USD")
  timezone        String       @default("America/Chicago")
  restaurants     Restaurant[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Restaurant {
  id                String             @id @default(cuid())
  tenantId          String
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name              String
  publicSlug        String             @unique
  phone             String?
  email             String?
  descriptionShort  String?
  descriptionLong   String?
  status            RestaurantStatus   @default(DRAFT)
  orderingEnabled   Boolean            @default(false)
  pickupEnabled     Boolean            @default(true)
  curbsideEnabled   Boolean            @default(false)
  deliveryEnabled   Boolean            @default(false)
  dineInInfoEnabled Boolean            @default(false)
  profile           RestaurantProfile?
  theme             BrandTheme?
  storySections     StorySection[]
  businessHours     BusinessHour[]
  serviceAreas      ServiceArea[]
  menus             Menu[]
  orders            Order[]
  promos            Promo[]
  playbookInstalls  PlaybookInstall[]
  rules             Rule[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  conversations     Conversation[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model RestaurantProfile {
  id            String     @id @default(cuid())
  tenantId      String
  restaurantId  String     @unique
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  storyHeadline String?
  storyBody     String?
  ownerStory    String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  postalCode    String?
  country       String?    @default("US")
  lat           Float?
  lng           Float?
  websiteUrl    String?
  instagramUrl  String?
  facebookUrl   String?
  tiktokUrl     String?
  parkingNotes  String?
  curbsideNotes String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([tenantId])
}

model BrandTheme {
  id             String     @id @default(cuid())
  tenantId       String
  restaurantId   String     @unique
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  logoUrl        String?
  coverImageUrl  String?
  primaryColor   String?
  secondaryColor String?
  accentColor    String?
  fontHeading    String?
  fontBody       String?
  heroLayout     String?
  themePreset    String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([tenantId])
}

model StorySection {
  id           String           @id @default(cuid())
  tenantId     String
  restaurantId String
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  type         StorySectionType
  title        String?
  subtitle     String?
  body         String?
  imageUrl     String?
  sortOrder    Int              @default(0)
  isPublished  Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([tenantId, restaurantId])
  @@index([restaurantId, sortOrder])
}

model BusinessHour {
  id           String      @id @default(cuid())
  tenantId     String
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dayOfWeek    Int
  openTime     String
  closeTime    String
  isClosed     Boolean     @default(false)
  serviceType  ServiceType @default(GENERAL)

  @@index([tenantId, restaurantId])
  @@index([restaurantId, dayOfWeek, serviceType])
}

model ServiceArea {
  id                 String     @id @default(cuid())
  tenantId           String
  restaurantId       String
  restaurant         Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name               String
  postalCodesJson    Json?
  radiusMiles        Float?
  deliveryFee        Decimal    @default(0) @db.Decimal(10, 2)
  minimumOrderAmount Decimal    @default(0) @db.Decimal(10, 2)
  isActive           Boolean    @default(true)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([tenantId, restaurantId])
}

model Menu {
  id           String         @id @default(cuid())
  tenantId     String
  restaurantId String
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  isActive     Boolean        @default(true)
  currency     String         @default("USD")
  categories   MenuCategory[]
  items        MenuItem[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([tenantId, restaurantId])
}

model MenuCategory {
  id          String     @id @default(cuid())
  tenantId    String
  menuId      String
  menu        Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  items       MenuItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tenantId, menuId])
  @@index([menuId, sortOrder])
}

model MenuItem {
  id             String                 @id @default(cuid())
  tenantId       String
  menuId         String
  categoryId     String
  menu           Menu                   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  category       MenuCategory           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  description    String?
  price          Decimal                @db.Decimal(10, 2)
  compareAtPrice Decimal?               @db.Decimal(10, 2)
  imageUrl       String?
  sku            String?
  isActive       Boolean                @default(true)
  isFeatured     Boolean                @default(false)
  isVegetarian   Boolean                @default(false)
  isVegan        Boolean                @default(false)
  isGlutenFree   Boolean                @default(false)
  spiceLevel     Int?
  allergenNotes  String?
  sortOrder      Int                    @default(0)
  modifierGroups ModifierGroup[]
  availability   MenuItemAvailability[]
  orderItems     OrderItem[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([menuId, slug])
  @@index([tenantId, menuId])
  @@index([categoryId, sortOrder])
}

model ModifierGroup {
  id            String           @id @default(cuid())
  tenantId      String
  menuItemId    String
  menuItem      MenuItem         @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name          String
  selectionType SelectionType    @default(SINGLE)
  minSelections Int              @default(0)
  maxSelections Int              @default(1)
  isRequired    Boolean          @default(false)
  sortOrder     Int              @default(0)
  options       ModifierOption[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([tenantId, menuItemId])
  @@index([menuItemId, sortOrder])
}

model ModifierOption {
  id              String        @id @default(cuid())
  tenantId        String
  modifierGroupId String
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  name            String
  priceDelta      Decimal       @default(0) @db.Decimal(10, 2)
  isDefault       Boolean       @default(false)
  isActive        Boolean       @default(true)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId, modifierGroupId])
  @@index([modifierGroupId, sortOrder])
}

model MenuItemAvailability {
  id            String    @id @default(cuid())
  tenantId      String
  menuItemId    String
  menuItem      MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  isAvailable   Boolean   @default(true)
  availableFrom DateTime?
  availableTo   DateTime?
  reason        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId, menuItemId])
}

model Customer {
  id              String            @id @default(cuid())
  tenantId        String
  firstName       String
  lastName        String?
  email           String?
  phone           String?
  preferredLocale String?
  marketingOptIn  Boolean           @default(false)
  smsOptIn        Boolean           @default(false)
  emailOptIn      Boolean           @default(false)
  notes           String?
  addresses       CustomerAddress[]
  orders          Order[]
  conversations   Conversation[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([tenantId])
  @@index([email])
  @@index([phone])
}

model CustomerAddress {
  id                   String   @id @default(cuid())
  tenantId             String
  customerId           String
  customer             Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label                String?
  addressLine1         String
  addressLine2         String?
  city                 String
  state                String
  postalCode           String
  country              String   @default("US")
  lat                  Float?
  lng                  Float?
  deliveryInstructions String?
  isDefault            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([tenantId, customerId])
}

model Order {
  id                String             @id @default(cuid())
  tenantId          String
  restaurantId      String
  customerId        String
  restaurant        Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customer          Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  orderNumber       String
  status            OrderStatus        @default(DRAFT)
  fulfillmentType   FulfillmentType    @default(PICKUP)
  sourceChannel     SourceChannel      @default(WEB)
  currency          String             @default("USD")
  subtotalAmount    Decimal            @default(0) @db.Decimal(10, 2)
  taxAmount         Decimal            @default(0) @db.Decimal(10, 2)
  serviceFeeAmount  Decimal            @default(0) @db.Decimal(10, 2)
  deliveryFeeAmount Decimal            @default(0) @db.Decimal(10, 2)
  tipAmount         Decimal            @default(0) @db.Decimal(10, 2)
  discountAmount    Decimal            @default(0) @db.Decimal(10, 2)
  totalAmount       Decimal            @default(0) @db.Decimal(10, 2)
  customerNotes     String?
  internalNotes     String?
  placedAt          DateTime?
  confirmedAt       DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  items             OrderItem[]
  statusEvents      OrderStatusEvent[]
  payment           Payment?
  fulfillment       Fulfillment?
  ledgerEntries     LedgerEntry[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([restaurantId, orderNumber])
  @@index([tenantId, restaurantId])
  @@index([customerId])
  @@index([status, createdAt])
}

model OrderItem {
  id                String              @id @default(cuid())
  tenantId          String
  orderId           String
  menuItemId        String?
  order             Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem          MenuItem?           @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  nameSnapshot      String
  unitPriceSnapshot Decimal             @db.Decimal(10, 2)
  quantity          Int                 @default(1)
  lineSubtotal      Decimal             @db.Decimal(10, 2)
  notes             String?
  sortOrder         Int                 @default(0)
  modifiers         OrderItemModifier[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([tenantId, orderId])
}

model OrderItemModifier {
  id                         String    @id @default(cuid())
  tenantId                   String
  orderItemId                String
  orderItem                  OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifierGroupNameSnapshot  String
  modifierOptionNameSnapshot String
  priceDeltaSnapshot         Decimal   @default(0) @db.Decimal(10, 2)
  quantity                   Int       @default(1)
  createdAt                  DateTime  @default(now())

  @@index([tenantId, orderItemId])
}

model OrderStatusEvent {
  id         String       @id @default(cuid())
  tenantId   String
  orderId    String
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus OrderStatus?
  toStatus   OrderStatus
  actorType  ActorType
  actorId    String?
  note       String?
  createdAt  DateTime     @default(now())

  @@index([tenantId, orderId])
  @@index([orderId, createdAt])
}

model Fulfillment {
  id                   String          @id @default(cuid())
  tenantId             String
  orderId              String          @unique
  driverId             String?
  order                Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver               Driver?         @relation(fields: [driverId], references: [id], onDelete: SetNull)
  type                 FulfillmentType @default(PICKUP)
  scheduledFor         DateTime?
  pickupName           String?
  pickupPhone          String?
  curbsideSpot         String?
  carColor             String?
  carModel             String?
  arrivalNotifiedAt    DateTime?
  handoffAt            DateTime?
  deliveryAddressId    String?
  deliveryInstructions String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([tenantId, orderId])
  @@index([driverId])
}

model Driver {
  id           String        @id @default(cuid())
  tenantId     String
  firstName    String
  lastName     String?
  phone        String
  email        String?
  status       DriverStatus  @default(INACTIVE)
  vehicleType  String?
  vehicleColor String?
  vehicleModel String?
  notes        String?
  fulfillments Fulfillment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([tenantId])
  @@index([phone])
}

model Conversation {
  id           String              @id @default(cuid())
  tenantId     String
  restaurantId String
  customerId   String?
  restaurant   Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customer     Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  channel      ConversationChannel
  status       ConversationStatus  @default(OPEN)
  startedAt    DateTime            @default(now())
  closedAt     DateTime?
  messages     Message[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([tenantId, restaurantId])
  @@index([customerId])
  @@index([status, createdAt])
}

model Message {
  id                String                @id @default(cuid())
  tenantId          String
  conversationId    String
  conversation      Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction         MessageDirection
  senderType        SenderType
  senderId          String?
  body              String
  messageType       MessageType           @default(TEXT)
  providerMessageId String?
  deliveryStatus    MessageDeliveryStatus @default(UNKNOWN)
  createdAt         DateTime              @default(now())

  @@index([tenantId, conversationId])
  @@index([providerMessageId])
}

model Payment {
  id                      String          @id @default(cuid())
  tenantId                String
  orderId                 String          @unique
  order                   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider                PaymentProvider @default(STRIPE)
  providerPaymentIntentId String?
  status                  PaymentStatus   @default(PENDING)
  currency                String          @default("USD")
  amountAuthorized        Decimal         @default(0) @db.Decimal(10, 2)
  amountCaptured          Decimal         @default(0) @db.Decimal(10, 2)
  amountRefunded          Decimal         @default(0) @db.Decimal(10, 2)
  capturedAt              DateTime?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  @@index([tenantId, status])
  @@index([providerPaymentIntentId])
}

model LedgerEntry {
  id          String          @id @default(cuid())
  tenantId    String
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type        LedgerEntryType
  amount      Decimal         @db.Decimal(10, 2)
  currency    String          @default("USD")
  description String?
  reference   String?
  createdAt   DateTime        @default(now())

  @@index([tenantId, orderId])
  @@index([type, createdAt])
}

model Promo {
  id                 String     @id @default(cuid())
  tenantId           String
  restaurantId       String
  restaurant         Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name               String
  code               String?
  type               PromoType
  value              Decimal    @db.Decimal(10, 2)
  minimumOrderAmount Decimal?   @db.Decimal(10, 2)
  startsAt           DateTime?
  endsAt             DateTime?
  usageLimit         Int?
  isActive           Boolean    @default(true)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([tenantId, restaurantId])
  @@index([restaurantId, code])
}

model Rule {
  id            String      @id @default(cuid())
  tenantId      String
  restaurantId  String?
  restaurant    Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name          String
  ruleType      RuleType
  conditionJson Json
  actionJson    Json
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([tenantId, restaurantId])
  @@index([ruleType, isActive])
}

model PlaybookInstall {
  id           String     @id @default(cuid())
  tenantId     String
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  playbookKey  String
  version      String
  installedAt  DateTime   @default(now())
  isActive     Boolean    @default(true)
  configJson   Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, playbookKey])
  @@index([tenantId, restaurantId])
}
