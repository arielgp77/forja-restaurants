APP_BASE_URL=http://localhost:3000

# Stripe Connect UX-first MVP
# Note: this uses OAuth-style connection for fast MVP wiring.
STRIPE_CONNECT_CLIENT_ID=
STRIPE_SECRET_KEY=
STRIPE_CONNECT_MODE=oauth_standard_mvp

# Square OAuth
SQUARE_ENVIRONMENT=sandbox
SQUARE_APP_ID=
SQUARE_APP_SECRET=
SQUARE_OAUTH_SCOPES=MERCHANT_PROFILE_READ PAYMENTS_WRITE PAYMENTS_READ ORDERS_READ ORDERS_WRITE

# Adyen hidden config defaults
ADYEN_ENVIRONMENT=test
